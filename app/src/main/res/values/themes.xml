<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Leanback" parent="Theme.Leanback.Browse">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:colorPrimary">@color/black</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:fontFamily">@font/space_mono</item>
        <item name="fontFamily">@font/space_mono</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="rowHeaderStyle">@style/CustomRowHeader</item>
    </style>

    <style name="CustomRowHeader" parent="Widget.Leanback.Row.Header">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginBottom">0dp</item>
        <item name="android:fontFamily">@font/space_mono</item>
    </style>

    <!-- Netflix-style Player Theme -->
    <style name="Theme.Player" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:fontFamily">@font/space_mono</item>
        <item name="fontFamily">@font/space_mono</item>
    </style>
</resources>
