<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/navbar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/navbar_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/navbar_padding_horizontal"
    android:paddingEnd="@dimen/navbar_padding_horizontal"
    android:clipToPadding="false">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:background="@drawable/navbar_item_selector"
        android:paddingStart="@dimen/navbar_item_padding_horizontal"
        android:paddingEnd="@dimen/navbar_item_padding_horizontal"
        android:paddingTop="@dimen/navbar_item_padding_vertical"
        android:paddingBottom="@dimen/navbar_item_padding_vertical"
        android:layout_marginEnd="@dimen/navbar_item_spacing">

        <ImageView
            android:id="@+id/nav_home_icon"
            android:layout_width="@dimen/navbar_icon_size"
            android:layout_height="@dimen/navbar_icon_size"
            android:src="@drawable/ic_home"
            android:contentDescription="Home"
            android:layout_marginEnd="@dimen/navbar_item_icon_margin"
            android:duplicateParentState="true"
            android:tint="@color/navbar_icon_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOME"
            android:duplicateParentState="true"
            android:textColor="@color/navbar_text_selector"
            android:textSize="@dimen/navbar_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Library -->
    <LinearLayout
        android:id="@+id/nav_movies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:background="@drawable/navbar_item_selector"
        android:paddingStart="@dimen/navbar_item_padding_horizontal"
        android:paddingEnd="@dimen/navbar_item_padding_horizontal"
        android:paddingTop="@dimen/navbar_item_padding_vertical"
        android:paddingBottom="@dimen/navbar_item_padding_vertical"
        android:layout_marginEnd="@dimen/navbar_item_spacing">

        <ImageView
            android:id="@+id/nav_movies_icon"
            android:layout_width="@dimen/navbar_icon_size"
            android:layout_height="@dimen/navbar_icon_size"
            android:src="@drawable/ic_movie"
            android:contentDescription="Library"
            android:layout_marginEnd="@dimen/navbar_item_icon_margin"
            android:duplicateParentState="true"
            android:tint="@color/navbar_icon_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIBRARY"
            android:duplicateParentState="true"
            android:textColor="@color/navbar_text_selector"
            android:textSize="@dimen/navbar_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Spacer to push Utilities to the right -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

    <!-- Search -->
    <LinearLayout
        android:id="@+id/nav_search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:background="@drawable/navbar_item_selector"
        android:paddingStart="@dimen/navbar_item_padding_horizontal"
        android:paddingEnd="@dimen/navbar_item_padding_horizontal"
        android:paddingTop="@dimen/navbar_item_padding_vertical"
        android:paddingBottom="@dimen/navbar_item_padding_vertical"
        android:layout_marginEnd="@dimen/navbar_item_spacing">

        <ImageView
            android:id="@+id/nav_search_icon"
            android:layout_width="@dimen/navbar_icon_size"
            android:layout_height="@dimen/navbar_icon_size"
            android:src="@drawable/ic_search"
            android:contentDescription="Search"
            android:layout_marginEnd="@dimen/navbar_item_icon_margin"
            android:duplicateParentState="true"
            android:tint="@color/navbar_icon_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEARCH"
            android:duplicateParentState="true"
            android:textColor="@color/navbar_text_selector"
            android:textSize="@dimen/navbar_text_size"
            android:textStyle="bold" />
    </LinearLayout>



    <!-- Settings -->
    <LinearLayout
        android:id="@+id/nav_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:focusable="true"
        android:clickable="true"
        android:background="@drawable/navbar_item_selector"
        android:paddingStart="@dimen/navbar_item_padding_horizontal"
        android:paddingEnd="@dimen/navbar_item_padding_horizontal"
        android:paddingTop="@dimen/navbar_item_padding_vertical"
        android:paddingBottom="@dimen/navbar_item_padding_vertical">

        <ImageView
            android:id="@+id/nav_settings_icon"
            android:layout_width="@dimen/navbar_icon_size"
            android:layout_height="@dimen/navbar_icon_size"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:layout_marginEnd="@dimen/navbar_item_icon_margin"
            android:duplicateParentState="true"
            android:tint="@color/navbar_icon_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETTINGS"
            android:duplicateParentState="true"
            android:textColor="@color/navbar_text_selector"
            android:textSize="@dimen/navbar_text_size"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
