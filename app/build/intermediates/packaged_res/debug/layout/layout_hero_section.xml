<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/hero_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:src="@drawable/backdrop_placeholder" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/hero_gradient" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="40dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="60dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintWidth_percent="0.9">

        <TextView
            android:id="@+id/hero_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Movie Title" />

        <LinearLayout
            android:id="@+id/hero_metadata_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="invisible"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/hero_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="8.5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="#B3FFFFFF"
                android:layout_marginHorizontal="4dp" />

            <TextView
                android:id="@+id/hero_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp"
                tools:text="2024" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="#B3FFFFFF"
                android:layout_marginHorizontal="4dp" />

            <TextView
                android:id="@+id/hero_language"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp"
                tools:text="English" />
        </LinearLayout>

        <TextView
            android:id="@+id/hero_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="4dp"
            tools:text="Movie description goes here. This is a sample text to show how the description will look like on the hero section." />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
